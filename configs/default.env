# InferenceProfiler experiment config
EXPERIMENT=infpro.test

# Infrastructure
TF_VAR_PROJECT=infpro
TF_VAR_REGION=us-east-2
TF_VAR_SERVER_INSTANCE_TYPE=g4dn.xlarge
TF_VAR_CLIENT_INSTANCE_TYPE=t4g.xlarge
TF_VAR_AVAILABILITY_ZONE=2
# TF_VAR_PROFILE goes in ../secrets.env

# Server Configuration
MODEL_ID=meta-llama/Llama-3.2-3B-Instruct
MAX_MODEL_LEN=2048
DTYPE=auto
TENSOR_PARALLEL_SIZE=1
PIPELINE_PARALLEL_SIZE=1
CHUNKED_PREFILL=--enable-chunked-prefill
#ENABLE_EAGER=--enforce-eager
#DISABLE_REQUEST_LOGS=--disable-log-requests
GPU_MEMORY_UTILIZATION=0.9
VLLM_LOGGING_LEVEL=INFO

# Profiler
INFPRO_DEBUG=0
INFPRO_INTERVAL=1000
INFPRO_HOST=server
INFPRO_PORT=8888
#INFPRO_DISABLED=container,process

# Bench
VLLM_HOST=server
VLLM_PORT=8000
VLLM_BACKEND=openai-chat
VLLM_ENDPOINT=/v1/chat/completions
DATASET_NAME=random
DATASET_PATH=""
BURSTINESS=1.0
RANDOM_RANGE_RATIO=0.0
NUM_PROMPTS=500
WARMUP_PROMPTS=10
REQUEST_RATE=inf
ITERATIONS=1
INPUT_LENS=512
OUTPUT_LENS=512
CONCURRENCY=50
OUTPUT_DIR=./results
